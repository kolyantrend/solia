# AI image generation — primary provider (at least one key required)
AI_PRIMARY_KEY="YOUR_API_KEY"
AI_PRIMARY_KEY_2=""
AI_PRIMARY_MODEL=""

# AI image generation — secondary provider (optional, used as primary with fallback)
AI_SECONDARY_TOKEN=""
AI_SECONDARY_TOKEN_2=""
AI_SECONDARY_TOKEN_3=""
AI_SECONDARY_URL=""
AI_SECONDARY_MODEL=""

# Solana RPC endpoint (Alchemy recommended, 30M CU/month free)
# Format: https://solana-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# Sign up: https://www.alchemy.com
VITE_SOLANA_RPC_URL=""

# SUPABASE: Required for database, storage, and auth.
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY_HERE"
